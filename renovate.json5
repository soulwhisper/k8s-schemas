{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>soulwhisper/renovate-config"],
  packageRules: [
    {
      description: "Auto-merge GitHub Actions non-major bumps",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch", "digest"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge CRD upstream",
      matchManagers: ["vendir"],
      groupName: "vendir crd schemas",
      groupSlug: "vendir",
      separateMajorMinor: false,
      separateMinorPatch: false,
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
  ],
}
